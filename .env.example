# Application
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_URL_BACKUP=
NEXT_PUBLIC_APP_NAME=SuperShop

# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Feature flag for SSR-enabled dashboard (set to 'true' to enable server-rendered summaries)
NEXT_PUBLIC_DASHBOARD_SSR_ENABLED=false

# (Monitoring removed)

# Advertising Configuration
# Set to 'adsense', 'custom', or 'both'
NEXT_PUBLIC_AD_PROVIDER=both
# Your Google AdSense Publisher/Client ID (e.g. ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# Optional custom AdSense slot IDs
NEXT_PUBLIC_ADSENSE_SLOT_POS_FOOTER=
NEXT_PUBLIC_ADSENSE_SLOT_INVENTORY_FOOTER=
NEXT_PUBLIC_ADSENSE_SLOT_LOGIN=
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD_FOOTER=

